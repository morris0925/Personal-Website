  .contact h2{
    font-family:var(--display); font-weight:600;
    font-size:clamp(30px,5vw,58px); letter-spacing:-.025em; line-height:1.02; margin:0 0 26px;
    font-variation-settings:"wdth" 88;
  }
  .contact-links{display:flex; flex-wrap:wrap; gap:10px; margin-bottom:52px;}
  .colophon{display:flex; justify-content:space-between; gap:16px; flex-wrap:wrap; border-top:1px solid var(--rule); padding-top:18px;}

  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation:none !important; transition:none !important;}
    .stream-body div{opacity:1 !important;}
    .caret{display:none;}
  }
</style>
