<style>
  :root{
    --paper:#E8EAEE;
    --panel:#DEE1E8;
    --ink:#10141B;
    --muted:#59616E;
    --rule:#C6CBD4;
    --accent:#1F3BFF;
    --signal:#F2B705;

    --display:"Bricolage Grotesque", system-ui, sans-serif;
    --body:"Instrument Sans", system-ui, sans-serif;
    --mono:"IBM Plex Mono", ui-monospace, monospace;

    --gutter:clamp(20px, 5vw, 72px);
    --maxw:1180px;
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:var(--body);
    font-size:16px;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  a{color:inherit;}
  ::selection{background:var(--accent); color:#fff;}
  :focus-visible{outline:2px solid var(--accent); outline-offset:3px;}

  .wrap{max-width:var(--maxw); margin:0 auto; padding-inline:var(--gutter);}

  .mono{
    font-family:var(--mono);
    font-size:11.5px;
    letter-spacing:.09em;
    text-transform:uppercase;
    color:var(--muted);
  }

  /* ---------- nav ---------- */
  .nav{
    position:sticky; top:0; z-index:20;
    background:color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--rule);
  }
  .nav-in{
    display:flex; align-items:center; justify-content:space-between;
    gap:16px; height:58px;
  }
  .brand{
    font-family:var(--mono); font-size:12.5px; letter-spacing:.06em;
    text-decoration:none; white-space:nowrap;
  }
  .brand b{font-weight:500;}
  .nav-links{display:flex; gap:22px; align-items:center;}
  .nav-links a{
    font-family:var(--mono); font-size:11.5px; letter-spacing:.09em;
    text-transform:uppercase; color:var(--muted); text-decoration:none;
    padding-block:6px; border-bottom:1px solid transparent;
  }
  .nav-links a:hover{color:var(--ink); border-bottom-color:var(--accent);}
  @media (max-width:720px){ .nav-links a:nth-child(-n+2){display:none;} }

  /* ---------- hero ---------- */
  .hero{padding-top:clamp(56px,9vw,110px); padding-bottom:clamp(48px,7vw,88px);}
  .hero-grid{display:grid; grid-template-columns:1.05fr .95fr; gap:clamp(28px,5vw,64px); align-items:end;}
  @media (max-width:900px){ .hero-grid{grid-template-columns:1fr; align-items:start;} }

  .eyebrow{display:flex; align-items:center; gap:10px; margin-bottom:24px;}
  .dot{width:7px; height:7px; background:var(--accent); border-radius:50%; flex:none;}

  h1{
    font-family:var(--display);
    font-weight:600;
    font-size:clamp(40px, 6.6vw, 84px);
    line-height:.98;
    letter-spacing:-.025em;
    margin:0 0 22px;
    font-variation-settings:"wdth" 88;
  }
  h1 em{font-style:normal; color:var(--accent);}
  .lede{
    font-size:clamp(16px,1.6vw,18.5px);
    color:var(--muted);
    max-width:44ch;
    margin:0 0 30px;
  }
  .lede strong{color:var(--ink); font-weight:600;}

  .cta-row{display:flex; flex-wrap:wrap; gap:10px;}
  .btn{
    font-family:var(--mono); font-size:11.5px; letter-spacing:.09em; text-transform:uppercase;
    text-decoration:none; padding:11px 18px; border:1px solid var(--ink);
    display:inline-block; transition:background .18s ease, color .18s ease, transform .18s ease;
  }
  .btn:hover{background:var(--ink); color:var(--paper); transform:translateY(-1px);}
  .btn.primary{background:var(--accent); border-color:var(--accent); color:#fff;}
  .btn.primary:hover{background:var(--ink); border-color:var(--ink);}

  /* ---------- stream panel (signature) ---------- */
  .stream{
    background:var(--panel);
    border:1px solid var(--rule);
    padding:16px 18px 18px;
    min-height:296px;
    display:flex; flex-direction:column;
  }
  .stream-head{
    display:flex; justify-content:space-between; gap:12px;
    padding-bottom:12px; margin-bottom:12px; border-bottom:1px solid var(--rule);
  }
  .stream-body{
    font-family:var(--mono); font-size:12px; line-height:1.85;
    color:var(--ink); flex:1; overflow:hidden;
  }
  .stream-body div{opacity:0; animation:appear .28s ease forwards;}
  .stream-body .k{color:var(--accent);}
  .stream-body .w{color:#8a6a00;}
  .stream-body .dim{color:var(--muted);}
  @keyframes appear{ from{opacity:0; transform:translateY(4px);} to{opacity:1; transform:none;} }
  .caret{display:inline-block; width:7px; height:13px; background:var(--accent); vertical-align:-2px; animation:blink 1.05s steps(1) infinite;}
  @keyframes blink{50%{opacity:0;}}

  /* ---------- section frame ---------- */
  .sec{padding-block:clamp(52px,7vw,92px); border-top:1px solid var(--rule);}
  .sec-head{display:flex; align-items:baseline; gap:16px; margin-bottom:38px;}
  .sec-head h2{
    font-family:var(--display); font-weight:600;
    font-size:clamp(22px,2.6vw,30px); letter-spacing:-.015em; margin:0;
    font-variation-settings:"wdth" 90;
  }
  .sec-head .rule{flex:1; height:1px; background:var(--rule);}

  /* ---------- log entries ---------- */
  .entry{
    display:grid; grid-template-columns:104px 1fr; gap:clamp(16px,3vw,40px);
    padding-block:30px; border-top:1px solid var(--rule);
  }
  .entry:first-of-type{border-top:none; padding-top:0;}
  @media (max-width:760px){ .entry{grid-template-columns:1fr; gap:12px;} }

  .offset{font-family:var(--mono); font-size:11.5px; color:var(--muted); letter-spacing:.06em;}
  .offset .num{color:var(--ink); display:block; font-size:13px; margin-bottom:6px;}
  .tag{
    display:inline-flex; align-items:center; gap:6px;
    font-family:var(--mono); font-size:10.5px; letter-spacing:.1em; text-transform:uppercase;
  }
  .tag::before{content:""; width:6px; height:6px; flex:none;}
  .tag.project::before{background:var(--accent);}
  .tag.research::before{background:var(--signal);}
  .tag.work::before{background:var(--ink);}

  .entry h3{
    font-family:var(--display); font-weight:600;
    font-size:clamp(20px,2.3vw,26px); letter-spacing:-.015em;
    margin:0 0 4px; font-variation-settings:"wdth" 92;
  }
  .role{font-family:var(--mono); font-size:11.5px; color:var(--muted); letter-spacing:.04em; margin:0 0 14px;}
  .entry ul{margin:0 0 16px; padding-left:0; list-style:none; max-width:70ch;}
  .entry li{position:relative; padding-left:20px; margin-bottom:9px;}
  .entry li::before{content:""; position:absolute; left:0; top:11px; width:9px; height:1px; background:var(--accent);}
  .stack{display:flex; flex-wrap:wrap; gap:6px;}
  .chip{
    font-family:var(--mono); font-size:10.5px; letter-spacing:.05em;
    border:1px solid var(--rule); padding:3px 8px; color:var(--muted); background:var(--panel);
  }
  .entry .links{display:flex; gap:14px; margin-top:14px;}
  .entry .links a{
    font-family:var(--mono); font-size:11px; letter-spacing:.08em; text-transform:uppercase;
    text-decoration:none; border-bottom:1px solid var(--accent); padding-bottom:2px;
  }
  .entry .links a:hover{color:var(--accent);}

  /* ---------- schema / skills ---------- */
  .schema{border:1px solid var(--rule); background:var(--panel);}
  .row{display:grid; grid-template-columns:180px 1fr; gap:20px; padding:15px 18px; border-top:1px solid var(--rule);}
  .row:first-child{border-top:none;}
  @media (max-width:640px){ .row{grid-template-columns:1fr; gap:8px;} }
  .row .field{font-family:var(--mono); font-size:11.5px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted);}
  .row .vals{font-family:var(--mono); font-size:12.5px; line-height:1.9;}

  /* ---------- education ---------- */
  .edu{display:grid; grid-template-columns:1fr 1fr; gap:clamp(20px,4vw,48px);}
  @media (max-width:760px){ .edu{grid-template-columns:1fr;} }
  .edu h3{font-family:var(--display); font-weight:600; font-size:22px; margin:0 0 4px; letter-spacing:-.01em;}
  .edu p{margin:0 0 8px; color:var(--muted); font-size:15px;}
  .edu .when{font-family:var(--mono); font-size:11.5px; letter-spacing:.07em; color:var(--muted); text-transform:uppercase;}

  /* ---------- footer ---------- */
