<script>
(function () {
  var lines = [
    '<span class="k">[kafka]</span> topic=github-events p=0 offset=48213 <span class="dim">ok</span>',
    '<span class="k">[arrow]</span> flushed 12,480 rows → parquet/date=2026-07-23',
    '<span class="k">[duckdb]</span> scan parquet · 41ms · 3 partitions pruned',
    '<span class="w">[detect]</span> push_rate z=3.9 · repo=apache/kafka',
    '<span class="k">[rag]</span> retrieved 5 neighbours from incident_notes',
    '<span class="k">[llm]</span> ranked 3 hypotheses · confidence=medium',
    '<span class="w">[policy]</span> auto-ticket deferred → awaiting human review',
    '<span class="dim">[lag] consumer lag 0 · caught up</span>'
  ];

  var el = document.getElementById('stream');
  if (!el) return;

  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduced) {
    el.innerHTML = lines.join('<br>');
    return;
  }

  var i = 0, timer;

  function step() {
    if (i >= lines.length) {
      timer = setTimeout(function () { el.innerHTML = ''; i = 0; step(); }, 3200);
      return;
    }
    var row = document.createElement('div');
    row.innerHTML = lines[i] + (i === lines.length - 1 ? ' <span class="caret"></span>' : '');
    el.appendChild(row);
    i++;
    timer = setTimeout(step, 620);
  }

  step();

  document.addEventListener('visibilitychange', function () {
    if (document.hidden) { clearTimeout(timer); } else { clearTimeout(timer); step(); }
  });
})();
</script>

